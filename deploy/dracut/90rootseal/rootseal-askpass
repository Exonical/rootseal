#!/bin/bash
# rootseal-askpass - watches for systemd password requests and responds with NBDE key
# Based on clevis-luks-askpass approach - fetches key from network server

set -o pipefail

trap 'exit 0' TERM

loop=
path=/run/systemd/ask-password
while getopts ":lp:" o; do
    case "${o}" in
    l) loop=true;;
    p) path="${OPTARG}";;
    *) ;;
    esac
done

# Check if network is available
has_network() {
    ip route 2>/dev/null | grep -q default
}

# Track which devices we've already unlocked
tried_devices=""

while true; do
    for question in "${path}"/ask.*; do
        [ ! -e "${question}" ] && continue

        d=
        s=
        while read -r line; do
            case "$line" in
                Id=cryptsetup:*) d="${line##Id=cryptsetup:}";;
                Socket=*) s="${line##Socket=}";;
            esac
        done < "$question"

        [ -b "${d}" ] || continue
        [ -S "${s}" ] || continue

        # Skip if we've already successfully unlocked this device
        case "$tried_devices" in
            *"$d:success"*) continue ;;
        esac

        # Wait for network before attempting unlock
        if ! has_network; then
            # Network not ready yet, will retry on next loop iteration
            continue
        fi

        uuid="$(cryptsetup luksUUID "${d}" 2>/dev/null)" || continue
        
        echo "rootseal-askpass: Attempting NBDE unlock for ${d} (UUID=${uuid})" >&2

        # Use unlock command to fetch key from server (key is now printable base64)
        if pt="$(/usr/local/bin/rootseal unlock --device="${d}" --key-only 2>/dev/null)"; then
            if [ -n "${pt}" ]; then
                # Reply to systemd with the passphrase
                if printf '%s' "${pt}" | /usr/lib/systemd/systemd-reply-password 1 "${s}"; then
                    echo "rootseal-askpass: Unlocked ${d} (UUID=${uuid}) successfully via NBDE" >&2
                    tried_devices="${tried_devices} ${d}:success"
                    continue
                else
                    echo "rootseal-askpass: Failed to reply with passphrase for ${d}" >&2
                fi
            fi
        else
            echo "rootseal-askpass: Failed to get key for ${d} from server" >&2
        fi
    done

    [ "${loop}" != true ] && break

    # Exit only once there are no remaining requests AND we've been running a while
    # (avoids exiting before cryptsetup has had a chance to drop ask.* files)
    remaining=$(ls "${path}"/ask.* 2>/dev/null) || true
    if [ -z "${remaining}" ] && [ -n "${tried_devices}" ]; then
        # Successfully handled at least one device and nothing left
        break
    fi

    sleep 0.5
done
